# Required
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_ALERT_CHANNEL_IDS=C0123456789,C0987654321

# Recommended
REPO_ROOTS=/absolute/path/to/hogangnono-api:/absolute/path/to/hogangnono-bot

# Optional core behavior
RUN_MODE=scan
# RUN_MODE=loop
ALERT_SOURCE_NAME=AlertNow
LLM_PROVIDER=codex
PREFER_CODEX_MCP=1
SLACK_DETAIL_AS_FILE=0
DRY_RUN=0

# Optional tuning
MAX_CONTEXT_CHARS=24000
CONTEXT_TIMEOUT_MS=60000
LLM_TIMEOUT_MS=900000
AWS_TIMEOUT_MS=10000
STARTUP_BACKFILL=0
STARTUP_BACKFILL_LOOKBACK_HOURS=72
STARTUP_BACKFILL_MESSAGE_LIMIT=100
POLL_LOOKBACK_HOURS=24
POLL_MESSAGE_LIMIT=100
MAX_MESSAGES_PER_SCAN=10
MAX_ANALYSES_PER_RUN=10
LOOP_INTERVAL_SECONDS=60

# Optional runtime paths
# STATE_FILE=.data/state.json
# APP_LOG_FILE=.data/runtime.log

# Legacy single-channel alias
# SLACK_ALERT_CHANNEL_ID=C0123456789
